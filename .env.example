# ============================================================================
# Wootify Instance Manager environment template
# ----------------------------------------------------------------------------
# Copy this file to `.env` and adjust only the values you need.
# Boolean values: true / false
# Integer values: plain numbers without quotes
# Empty values are allowed for optional settings unless noted otherwise.
# ============================================================================

# ----------------------------------------------------------------------------
# Server / public callback URLs
# ----------------------------------------------------------------------------

# Base URL that external systems use to reach this API.
# Use your public hostname in production, for example behind Nginx or a tunnel.
SERVER_BASE_URL=http://localhost:8000


# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------

# Main SQLAlchemy connection URL.
# SQLite example:
# DATABASE_URL=sqlite:///C:/path/to/wootify.db
# PostgreSQL base URL example:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/
DATABASE_URL=sqlite:///C:/path/to/wootify.db

# Target PostgreSQL database name.
# Used only when DATABASE_URL points to a PostgreSQL server URL.
# The app combines DATABASE_URL + DATABASE_NAME into the final runtime database.
DATABASE_NAME=wootify_instance_manager_pg

# When true and PostgreSQL is selected, create DATABASE_NAME automatically
# if it does not already exist.
DATABASE_AUTO_CREATE=true

# Administrative PostgreSQL database used only for CREATE DATABASE checks.
# Typical values: postgres, template1
POSTGRES_ADMIN_DATABASE=postgres

# SQLite source URL used by the one-time migration script when importing
# existing SQLite data into PostgreSQL.
SQLITE_MIGRATION_SOURCE_URL=sqlite:///C:/path/to/wootify.db

# SQLite busy timeout in milliseconds.
# Applies only when DATABASE_URL is a SQLite database.
SQLITE_BUSY_TIMEOUT_MS=30000

# SQLite journal mode.
# Common values: WAL, DELETE, TRUNCATE
# Applies only when DATABASE_URL is a SQLite database.
SQLITE_JOURNAL_MODE=WAL


# ----------------------------------------------------------------------------
# Chatwoot
# ----------------------------------------------------------------------------

# Base URL of your Chatwoot installation.
CHATWOOT_BASE_URL=http://localhost:3000

# Global Chatwoot API access token used by server-side API calls.
# Leave empty if you configure tokens per instance elsewhere and do not need
# a global default.
CHATWOOT_API_TOKEN=

# Enable status change notifications from Chatwoot back to Bale/Telegram users.
CHATWOOT_STATUS_NOTIFY_TO_BALE=true

# Message sent when a conversation becomes open.
CHATWOOT_STATUS_MESSAGE_OPEN=Your chat has been opened.

# Message sent when a conversation is opened by a specific operator.
# `{operator_name}` will be replaced at runtime.
CHATWOOT_STATUS_MESSAGE_OPEN_BY_OPERATOR=Your chat has been opened by {operator_name}.

# Message sent when a conversation is resolved.
CHATWOOT_STATUS_MESSAGE_RESOLVED=Your chat has been resolved.

# Message sent when a conversation is moved to pending.
CHATWOOT_STATUS_MESSAGE_PENDING=Your chat is pending.

# Message sent when a conversation is snoozed.
CHATWOOT_STATUS_MESSAGE_SNOOZED=Your chat has been snoozed.


# ----------------------------------------------------------------------------
# Bale Bot API
# ----------------------------------------------------------------------------

# Bale Bot API base URL.
BALE_API_BASE_URL=https://tapi.bale.ai

# Bale file-download base URL.
BALE_FILE_BASE_URL=https://tapi.bale.ai/file

# Delay between Bale polling cycles in seconds.
BALE_POLL_INTERVAL_SECONDS=5

# Long-poll timeout for Bale getUpdates calls in seconds.
BALE_LONG_POLL_TIMEOUT_SECONDS=25

# Show the generic "share phone number" keyboard button in non-enterprise flows.
BALE_SHARE_PHONE_BUTTON=true

# Label of the generic Bale share-phone button.
BALE_SHARE_PHONE_BUTTON_TEXT=Share phone number

# Default response text for `/start` in non-enterprise Bale flows.
BALE_START_MESSAGE_TEXT=Send message and wait for our operators to respond pls

# Prompt text used when asking the user to share their phone number in Bale.
BALE_SHARE_PHONE_PROMPT_TEXT=Use the button below to share your phone number. Commands: /share_phone, /help


# ----------------------------------------------------------------------------
# Enterprise Bale SMS synchronization
# ----------------------------------------------------------------------------

# Enable periodic polling of the external SMS provider and forward matching
# inbound SMS messages to enterprise Bale users.
ENTERPRISE_SMS_SYNC_ENABLED=false

# External SMS API endpoint used for fetching new SMS records.
ENTERPRISE_SMS_API_URL=https://apiserver.novinmed.com/SoftNoNTFC/LastId

# Authentication token for the SMS API.
ENTERPRISE_SMS_API_TOKEN=

# HTTP header name used to send the SMS API token.
ENTERPRISE_SMS_TOKEN_HEADER=Authorization

# Optional token prefix added before ENTERPRISE_SMS_API_TOKEN.
# Examples: Bearer, Token
ENTERPRISE_SMS_TOKEN_PREFIX=

# Polling interval in minutes between SMS sync runs.
ENTERPRISE_SMS_POLL_INTERVAL_MINUTES=20

# Starting message ID for the first sync run.
# Leave at 0 to start from the earliest available record that the provider returns.
ENTERPRISE_SMS_INITIAL_LAST_ID=0

# HTTP timeout in seconds for SMS provider requests.
ENTERPRISE_SMS_HTTP_TIMEOUT_SECONDS=30

# When true, write per-phone SMS delivery debug logs under data/tmp-enterprise-smoke.
ENTERPRISE_SMS_FILE_LOG_ENABLED=false


# ----------------------------------------------------------------------------
# Telegram Bot API
# ----------------------------------------------------------------------------

# Telegram Bot API base URL.
TELEGRAM_API_BASE_URL=https://api.telegram.org/bot

# Telegram file-download base URL.
TELEGRAM_FILE_BASE_URL=https://api.telegram.org/file/bot

# Delay between Telegram polling cycles in seconds.
TELEGRAM_POLL_INTERVAL_SECONDS=5

# Long-poll timeout for Telegram getUpdates calls in seconds.
TELEGRAM_LONG_POLL_TIMEOUT_SECONDS=25

# Show the generic "share phone number" keyboard button in Telegram flows.
TELEGRAM_SHARE_PHONE_BUTTON=true

# Label of the generic Telegram share-phone button.
TELEGRAM_SHARE_PHONE_BUTTON_TEXT=Share phone number

# Default response text for `/start` in Telegram flows.
TELEGRAM_START_MESSAGE_TEXT=Send message and wait for our operators to respond pls

# Prompt text used when asking the user to share their phone number in Telegram.
TELEGRAM_SHARE_PHONE_PROMPT_TEXT=Use the button below to share your phone number. Commands: /share_phone, /help


# ----------------------------------------------------------------------------
# Encryption and payload retention
# ----------------------------------------------------------------------------

# Fernet key used to encrypt instance metadata and Chatwoot configuration at rest.
# Generate one with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# In production this should always be set explicitly and kept secret.
DATA_ENCRYPTION_KEY=

# When true, store sanitized raw message payload snapshots in message mappings.
# Useful for debugging; disable if you want to minimize stored payload data.
STORE_MESSAGE_PAYLOADS=false


# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------

# Application log level.
# Common values: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# When true, include message bodies in logs.
# Enable only for troubleshooting because it can expose user content.
LOG_MESSAGE_CONTENT=false

# Maximum number of characters kept when truncating payloads in logs.
LOG_PAYLOAD_TRUNCATE=200

# Redact sensitive values such as API tokens in logs when possible.
LOG_REDACT_SECRETS=true

# Log each HTTP request handled by the FastAPI application.
LOG_HTTP_REQUESTS=false

# Enable ANSI color output for console logs.
LOG_COLOR=true

# Force ANSI colors even when stdout/stderr is redirected.
# Usually leave this false for services writing to files or systemd/journald.
LOG_COLOR_FORCE=false
