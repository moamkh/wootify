# Server
SERVER_BASE_URL=http://localhost:8000

# Database
# DATABASE_URL=sqlite:///C:/path/to/wootify.db
SQLITE_BUSY_TIMEOUT_MS=30000
SQLITE_JOURNAL_MODE=WAL

# Encryption key for instance metadata/chatwoot config (Fernet key).
# Example generator:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=

# Persist sanitized raw payload snapshots in message mappings.
STORE_MESSAGE_PAYLOADS=false

# Logging
LOG_LEVEL=INFO
LOG_MESSAGE_CONTENT=false
LOG_PAYLOAD_TRUNCATE=200
LOG_REDACT_SECRETS=true
LOG_HTTP_REQUESTS=false
LOG_COLOR=true
# Force ANSI colors even when output is redirected (not recommended for file logs).
LOG_COLOR_FORCE=false

# Bale (Bot API)
BALE_API_BASE_URL=https://tapi.bale.ai
BALE_FILE_BASE_URL=https://tapi.bale.ai/file
BALE_POLL_INTERVAL_SECONDS=5
BALE_LONG_POLL_TIMEOUT_SECONDS=25
BALE_SHARE_PHONE_BUTTON=true
BALE_SHARE_PHONE_BUTTON_TEXT=Share phone number
BALE_START_MESSAGE_TEXT=Send message and wait for our operators to respond pls
BALE_SHARE_PHONE_PROMPT_TEXT=Use the button below to share your phone number. Commands: /share_phone, /help

# Telegram (Bot API)
TELEGRAM_API_BASE_URL=https://api.telegram.org/bot
TELEGRAM_FILE_BASE_URL=https://api.telegram.org/file/bot
TELEGRAM_POLL_INTERVAL_SECONDS=5
TELEGRAM_LONG_POLL_TIMEOUT_SECONDS=25
TELEGRAM_SHARE_PHONE_BUTTON=true
TELEGRAM_SHARE_PHONE_BUTTON_TEXT=Share phone number
TELEGRAM_START_MESSAGE_TEXT=Send message and wait for our operators to respond pls
TELEGRAM_SHARE_PHONE_PROMPT_TEXT=Use the button below to share your phone number. Commands: /share_phone, /help

# Chatwoot conversation status -> Bale notifications
CHATWOOT_STATUS_NOTIFY_TO_BALE=true
CHATWOOT_STATUS_MESSAGE_OPEN=Your chat has been opened.
CHATWOOT_STATUS_MESSAGE_OPEN_BY_OPERATOR=Your chat has been opened by {operator_name}.
CHATWOOT_STATUS_MESSAGE_RESOLVED=Your chat has been resolved.
CHATWOOT_STATUS_MESSAGE_PENDING=Your chat is pending.
CHATWOOT_STATUS_MESSAGE_SNOOZED=Your chat has been snoozed.

# Enterprise Bale SMS Synchronization
# Configuration for receiving SMS messages from external SMS provider and forwarding to Bale users.
# Enable/disable SMS sync polling.
ENTERPRISE_SMS_SYNC_ENABLED=false
# External SMS API endpoint URL for fetching new messages.
ENTERPRISE_SMS_API_URL=https://apiserver.novinmed.com/SoftNoNTFC/LastId
# Authentication token for SMS API requests.
ENTERPRISE_SMS_API_TOKEN=
# HTTP header name used for authentication (default: Authorization).
ENTERPRISE_SMS_TOKEN_HEADER=Authorization
# Optional prefix for the token value (e.g., 'Bearer', 'Token').
ENTERPRISE_SMS_TOKEN_PREFIX=
# Polling interval in minutes for fetching new SMS messages.
ENTERPRISE_SMS_POLL_INTERVAL_MINUTES=20
# Initial SMS ID to start syncing from (0 = start from earliest available).
ENTERPRISE_SMS_INITIAL_LAST_ID=0
# HTTP request timeout in seconds for SMS API calls.
ENTERPRISE_SMS_HTTP_TIMEOUT_SECONDS=30
# Enable filesystem logging of SMS messages for debugging/auditing.
# Creates per-phone folders in data/tmp-enterprise-smoke/ph_<phonenumber>/ with delivery logs.
ENTERPRISE_SMS_FILE_LOG_ENABLED=false
